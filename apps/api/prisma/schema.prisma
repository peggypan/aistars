// Prisma Schema for AI Stars - SQLite Compatible
// 简化版 MVP Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 演员模型 - MVP简化版
model Star {
  id          String   @id @default(uuid())
  name        String   // 艺名
  avatar      String?  // 头像URL
  
  // 基础信息
  age         Int
  gender      String   // male/female/other (SQLite不支持enum)
  nationality String
  
  // 人物设定 (JSON存储数组)
  personality String?  // JSON: ["冷静", "理性"]
  background  String?  // 背景故事
  skills      String?  // JSON: ["编程", "格斗"]
  
  // 形象
  appearance  String?  // 外貌描述
  style       String?  // 穿搭风格（自由输入）
  stylePreset String?  // 风格预选：elegant/street/vintage/casual/business/sporty
  signature   String?  // 标志性特征
  
  // 性格预选
  personalityPreset String? // 性格预选：calm/energetic/rational/emotional/confident/shy/humorous/serious
  
  // 分类 (逗号分隔的ID列表)
  categories  String?  // JSON: ["cat1", "cat2"]
  
  // 作品 (JSON存储)
  movies      String?  // JSON: [{"id": "m1", "title": "xxx", "roleName": "主角"}]
  
  // AI生成信息
  aiGenerated Boolean  @default(true)
  aiPrompt    String?  // 生成提示词
  
  // 统计
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("t_stars")
}

// 分类模型
model Category {
  id          String   @id @default(uuid())
  name        String   // 分类名称
  type        String   // actor/singer/host/model/other
  icon        String?
  description String?
  starCount   Int      @default(0)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("t_categories")
}

// 作品模型
model Movie {
  id          String   @id @default(uuid())
  title       String
  type        String   // movie/tv/variety/music/ad/short
  poster      String?
  releaseYear Int
  genre       String?  // JSON: ["科幻", "动作"]
  description String?
  duration    Int?
  rating      Float?
  
  // 参演演员 (JSON存储)
  stars       String?  // JSON: [{"starId": "s1", "roleName": "主角"}]
  
  aiGenerated Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("t_movies")
}

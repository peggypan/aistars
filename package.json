{
  "name": "aistars",
  "version": "0.1.0",
  "description": "AI影视演员库 - AI-generated virtual actors for film production",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:studio": "cd apps/api && npx prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^1.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}